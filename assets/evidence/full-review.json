                "source_code": "import ast\nfrom typing import Dict, Any, Union\n\nclass UnsafeExpression(Exception):\n    \"\"\"Raised when an expression contains unsupported syntax or unsafe operations.\"\"\"\n    pass\n\ndef evaluate_rule(expression: str, record: Dict[str, Any]) -> bool:\n    # 1. Validate that all values in the record are scalar (int, float, str, bool, None)\n    for k, v in record.items():\n        if v is not None and not isinstance(v, (int, float, str, bool)):\n            raise UnsafeExpression(\"Only scalar record values are accepted\")\n\n    # 2. Parse the expression using Python's AST\n    try:\n        tree = ast.parse(expression, mode='eval')\n    except SyntaxError as e:\n        raise UnsafeExpression(f\"Syntax error: {e}\")\n\n    # 3. Traverse and validate the AST to prevent arbitrary code execution, attribute access, and function calls\n    for node in ast.walk(tree):\n        # We only allow: Expression, Constant, Name, Load, and simple binary/unary/comparison operators\n        if isinstance(node, (ast.Expression, ast.Constant, ast.Load)):\n            continue\n        elif isinstance(node, ast.Name):\n            # Ensure the name referenced exists in our record\n            if node.id not in record:\n                raise UnsafeExpression(f\"unknown name: {node.id}\")\n        elif isinstance(node, (ast.BinOp, ast.UnaryOp, ast.Compare)):\n            continue\n        elif isinstance(node, (ast.Add, ast.Sub, ast.Mult, ast.Div, ast.Mod, ast.Pow,\n                               ast.USub, ast.UAdd, ast.Not,\n                               ast.Eq, ast.NotEq, ast.Lt, ast.LtE, ast.Gt, ast.GtE, ast.In, ast.NotIn, ast.Is, ast.IsNot)):\n            continue\n        elif isinstance(node, ast.BoolOp):\n            continue\n        elif isinstance(node, (ast.And, ast.Or)):\n            continue\n        else:\n            raise UnsafeExpression(f\"unsupported syntax node: {type(node).__name__}\")\n\n    # 4. Safely compile and evaluate the expression using a restricted global dictionary containing only the allowed record variables\n    try:\n        compiled = compile(tree, filename=\"<string>\", mode=\"eval\")\n        # Ensure __builtins__ is strictly empty\n        result = eval(compiled, {\"__builtins__\": {}}, record)\n        return bool(result)\n    except Exception as e:\n        raise UnsafeExpression(f\"Evaluation error: {e}\")\n",
